---
layout: null
sitemap: false
---
[
{% assign pages = site.html_pages | where_exp: "p", "p.url != '/search.json'" %}
{% for page in pages %}
  {
    "url": {{ page.url | relative_url | jsonify }},
    "path": {{ page.path | jsonify }},
    "title": {{ page.title | default: page.name | jsonify }},
    "content": {{ page.content | markdownify | strip_html | replace: '　', ' ' | strip_newlines | truncate: 800 | jsonify }}
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]
